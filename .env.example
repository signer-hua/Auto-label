# ==================== Auto-label 环境配置 ====================
# 复制此文件为 .env 并根据你的实际环境修改

# ==================== 权重文件目录 ====================
# 默认为项目同级的 weights/ 目录（即 e:\auto-label\weights）
# WEIGHTS_DIR=E:\auto-label\weights

# ==================== Redis 配置 ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# ==================== 模型配置 ====================
# SAM3 权重路径（留空则自动从 HuggingFace 下载）
# SAM3_CHECKPOINT=E:\auto-label\weights\sam3.pt

# DINOv3 权重路径（留空则通过 torch.hub 下载）
# DINO_WEIGHTS_PATH=E:\auto-label\weights\dinov3_vits16_pretrain_lvd1689m-08c60483.pth

# Grounding DINO 模型（HuggingFace Hub 名称或本地目录路径）
# 首次使用时会自动下载到 HuggingFace 缓存目录
GROUNDING_DINO_MODEL_NAME=IDEA-Research/grounding-dino-base

# 推理设备
SAM3_DEVICE=cuda
DINO_DEVICE=cuda
GROUNDING_DINO_DEVICE=cuda

# ==================== 检测阈值 ====================
GROUNDING_DINO_SCORE_THR=0.3
GROUNDING_DINO_BOX_THR=0.3
GROUNDING_DINO_SCORE_THR_LOW=0.2

# ==================== 服务器配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
STATIC_URL_PREFIX=http://localhost:8000
